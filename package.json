{
  "name": "lifehub-desktop",
  "version": "1.3.0",
  "description": "LifeHub — 43 productivity tools in one app",
  "main": "main.js",
  "author": "LifeHub <hello@trylifehub.com>",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build-mac": "electron-builder --mac",
    "build-mac-store": "electron-builder --mac mas",
    "build-win": "electron-builder --win",
    "build-win-store": "electron-builder --win appx",
    "build-linux": "electron-builder --linux",
    "build-linux-snap": "electron-builder --linux snap",
    "build-all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.lifehub.desktop",
    "productName": "LifeHub",
    "copyright": "© 2026 LifeHub",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "build/icon.*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg",  "arch": ["arm64", "x64"] },
        { "target": "zip",  "arch": ["arm64", "x64"] }
      ],
      "artifactName": "LifeHub-mac-${arch}.${ext}",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "LifeHub does not use the camera.",
        "NSMicrophoneUsageDescription": "LifeHub does not use the microphone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "mas": {
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "LifeHub-mac-store-${arch}.${ext}"
    },
    "dmg": {
      "title": "LifeHub Installer",
      "icon": "build/icon.icns",
      "iconSize": 110,
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 200, "type": "file" },
        { "x": 400, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "LifeHub-windows-${arch}.${ext}"
    },
    "appx": {
      "applicationId": "LifeHub",
      "displayName": "LifeHub",
      "publisherDisplayName": "LifeHub",
      "identityName": "LifeHub.Desktop",
      "backgroundColor": "#0a0a0b",
      "languages": ["en-US", "ar-SA"],
      "artifactName": "LifeHub-windows-store-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LifeHub"
    },
    "linux": {
      "icon": "build/icon-1024.png",
      "category": "Office",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "LifeHub-linux-${arch}.${ext}"
    },
    "snap": {
      "summary": "43 productivity tools in one app",
      "grade": "stable",
      "confinement": "strict",
      "publish": "github"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "walymali",
        "repo": "lifehub-desktop",
        "private": false,
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
