{
  "name": "lifeboard",
  "version": "1.0.0",
  "description": "Personal Dashboard - Tasks, Habits, Goals, Pomodoro & more",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.lifeboard.app",
    "productName": "LifeBoard",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "files": [
      "main.js",
      "app.html"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8"
  }
}
